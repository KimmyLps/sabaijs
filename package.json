{
  "name": "sabaijs",
  "version": "0.1.1",
  "description": "An all-in-one Node.js utility toolkit — Thai-locale helpers (address parsing, geography, validators, date) plus general-purpose utilities (collections, batch file processing).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./address": {
      "import": "./dist/address/index.js",
      "require": "./dist/address/index.cjs",
      "types": "./dist/address/index.d.ts"
    },
    "./bank": {
      "import": "./dist/bank/index.js",
      "require": "./dist/bank/index.cjs",
      "types": "./dist/bank/index.d.ts"
    },
    "./batch": {
      "import": "./dist/batch/index.js",
      "require": "./dist/batch/index.cjs",
      "types": "./dist/batch/index.d.ts"
    },
    "./currency": {
      "import": "./dist/currency/index.js",
      "require": "./dist/currency/index.cjs",
      "types": "./dist/currency/index.d.ts"
    },
    "./geography": {
      "import": "./dist/geography/index.js",
      "require": "./dist/geography/index.cjs",
      "types": "./dist/geography/index.d.ts"
    },
    "./collection": {
      "import": "./dist/collection/index.js",
      "require": "./dist/collection/index.cjs",
      "types": "./dist/collection/index.d.ts"
    },
    "./date": {
      "import": "./dist/date/index.js",
      "require": "./dist/date/index.cjs",
      "types": "./dist/date/index.d.ts"
    },
    "./invoice": {
      "import": "./dist/invoice/index.js",
      "require": "./dist/invoice/index.cjs",
      "types": "./dist/invoice/index.d.ts"
    },
    "./quotation": {
      "import": "./dist/quotation/index.js",
      "require": "./dist/quotation/index.cjs",
      "types": "./dist/quotation/index.d.ts"
    },
    "./receipt": {
      "import": "./dist/receipt/index.js",
      "require": "./dist/receipt/index.cjs",
      "types": "./dist/receipt/index.d.ts"
    },
    "./text": {
      "import": "./dist/text/index.js",
      "require": "./dist/text/index.cjs",
      "types": "./dist/text/index.d.ts"
    },
    "./validators": {
      "import": "./dist/validators/index.js",
      "require": "./dist/validators/index.cjs",
      "types": "./dist/validators/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sabaijs",
    "thai",
    "address",
    "validator",
    "geography",
    "collection",
    "date",
    "province",
    "amphoe",
    "tambon",
    "zipcode",
    "citizen-id",
    "batch-processing",
    "toolkit"
  ],
  "author": "kimmylps.dev@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
